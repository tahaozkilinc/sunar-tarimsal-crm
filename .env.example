# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# Vercel'de aynı değişkenleri "Environment Variables" bölümüne ekleyin.

# Supabase proje URL'i (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable / anon key (istemci tarafı, paylaşılması güvenli)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service role key (SADECE sunucu tarafı, gizli tutun!) - admin kullanıcı oluşturma
# ve İthalat cron'u (RLS bypass) için
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- İthalat (TÜİK karşılaştırması) otomatik çekme -------------------------
# BM Comtrade API anahtarı (OPSİYONEL). Tanımlıysa yüksek limitli kimlikli uç
# nokta, tanımlı değilse anahtarsız "preview" uç noktası kullanılır. Ücretsiz
# anahtar: https://comtradedeveloper.un.org
COMTRADE_API_KEY=

# Vercel Cron gizli anahtarı (OPSİYONEL ama önerilir). Tanımlıysa
# /api/imports/cron yalnızca "Authorization: Bearer <CRON_SECRET>" ile çalışır.
CRON_SECRET=

# --- TÜİK SDMX (yeni veri portalı) doğrudan çekme -------------------------
# TÜİK'in yeni portalı (veriportali.tuik.gov.tr) SDMX REST API sunar; 12 haneli
# GTİP'i BİREBİR verir (Comtrade'in HS6'sından farklı). Etkinleştirmek için:
#   TUIK_API_KEY       : portaldan alınan abonelik anahtarı
#   TUIK_SDMX_TEMPLATE : tam sorgu URL şablonu; {hs} {start} {end} yer tutuculu.
#                        Portalın API/SDMX çıktısındaki URL'de GTİP ve tarihleri
#                        {hs}/{start}/{end} ile değiştirerek elde edilir.
#   TUIK_API_KEY_HEADER: anahtar başlığı (varsayılan Ocp-Apim-Subscription-Key)
#   TUIK_QTY_DIVISOR   : miktar kg dönerse 1000 (tona çevirir); varsayılan 1
TUIK_API_KEY=
TUIK_SDMX_TEMPLATE=
TUIK_API_KEY_HEADER=
TUIK_QTY_DIVISOR=
